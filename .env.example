# Copy this file to `.env` and fill in the real values.
# `.env` is gitignored so the real credentials don't land in git.

# Pooler connection — used by the running FastAPI app.
# Supabase dashboard → Project Settings → Database → Connection pooling
# → Transaction mode.
DATABASE_URL=postgresql+psycopg://postgres.<project-ref>:<password>@aws-<N>-<region>.pooler.supabase.com:6543/postgres

# Direct connection — used by Alembic only.
# Supabase dashboard → Project Settings → Database → Connection info.
DIRECT_DATABASE_URL=postgresql+psycopg://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres
